{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://games.herzi.ai/schemas/manifest.schema.json",
  "title": "HTML5 Game Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "version", "entrypoint"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable URL-safe game identifier.",
      "pattern": "^[a-z0-9][a-z0-9-]{2,62}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "entrypoint": {
      "type": "string",
      "default": "index.html",
      "pattern": "^[A-Za-z0-9._/-]+\\.html$"
    },
    "author": {
      "type": "string",
      "maxLength": 120
    },
    "tags": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 32
      },
      "uniqueItems": true
    },
    "thumbnail": {
      "type": "string",
      "description": "Optional relative path to a thumbnail inside the ZIP.",
      "pattern": "^[A-Za-z0-9._/-]+\\.(png|jpg|jpeg|webp|svg)$"
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 80
      }
    }
  }
}

